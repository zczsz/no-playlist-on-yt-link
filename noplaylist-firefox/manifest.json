{
    "manifest_version": 2,
    "name": "No Playlist on Youtube Links",
    "description": "Remove playlists from Youtube urls",
    "version": "1.0",

    "background": {
        "scripts": [
            "background.js"
        ],
        "persistent": false
    },

    "permissions": [
        "activeTab",
        "contextMenus",
        "clipboardWrite"
    ]
}
