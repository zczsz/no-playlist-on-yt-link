{
  "manifest_version": 3,
  "name": "No Playlist on Youtube Links",
  "description": "Remove playlists from Youtube urls",
  "version": "1.0",

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "contextMenus",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ]
}